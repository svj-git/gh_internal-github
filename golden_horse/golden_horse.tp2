// Captain Prangl group
COPY ~golden_horse/cre_other/rqcappra.cre~ ~override/rqcappra.cre~
  WRITE_ASCII 0x280 ~rqcappra~ #32 // Script name aka Death Variable
  WRITE_ASCII 0x2cc ~rq1cappr~ #8 // Dialogue file
  WRITE_ASCII 0x248 ~SHOUTDLG~ #8 // Override script
  WRITE_ASCII 0x250 ~rqgpuse~ #8 // Class script
  ADD_CRE_ITEM ~rqletpra~ #0 #0 #0 ~UNSTEALABLE~ ~INV~
  SAY NAME1 ~Captain Prangl~
  SAY NAME2 ~Captain Prangl~

