// Holy symbol of Bhaal
COPY ~golden_horse/itm/rqhosy1.itm~ ~override/rqhosy1.itm~
/* Unidentified name */
SAY NAME1 ~Holy symbol of Bhaal~
/* Identified name */
SAY NAME2 ~Holy symbol of Bhaal~
