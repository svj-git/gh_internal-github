// Mercenaries
COPY ~golden_horse/cre_allies/rqfbe.cre~ ~override/rqfbe.cre~
  WRITE_ASCII 0x280 ~rqfbe~ #32 // Script name aka Death Variable
  WRITE_ASCII 0x2cc ~rqfbe~ #8 // Dialogue file
  SAY BIO ~I be workin' as mercenary for Golden Horse and thats all yer be needin' to know bout' me.~
  SAY NAME1 ~Jorgur~
  SAY NAME2 ~Jorgur~

COPY ~golden_horse/cre_allies/rqfbet.cre~ ~override/rqfbet.cre~
  WRITE_ASCII 0x280 ~rqfbet~ #32 // Script name aka Death Variable
  WRITE_ASCII 0x2cc ~rqfbet~ #8 // Dialogue file
  SAY BIO ~I be brother to Jorgur not ye' so ye wastin' yer breath talkin' to me.~
  SAY NAME1 ~Breneke~
  SAY NAME2 ~Breneke~

COPY ~golden_horse/cre_allies/rqmil.cre~ ~override/rqmil.cre~
  WRITE_ASCII 0x280 ~rqmil~ #32 // Script name aka Death Variable
  WRITE_ASCII 0x2cc ~rqmil~ #8 // Dialogue file
  SAY BIO ~I was alchemist assistant but some of my experiments... Lets just not go into any details. Say what were we talking about?~
  SAY NAME1 ~Kelrp Munor~
  SAY NAME2 ~Kelrp Munor~

COPY ~golden_horse/cre_allies/rqfmn.cre~ ~override/rqfmn.cre~
  WRITE_ASCII 0x280 ~rqfmn~ #32 // Script name aka Death Variable
  WRITE_ASCII 0x2cc ~rqfmn~ #8 // Dialogue file
  SAY BIO ~My past you say. I was in militia they trained me as soldier though I am good warior now I would like to cross-train to become mage.~
  SAY NAME1 ~Kylos~
  SAY NAME2 ~Kylos~

COPY ~golden_horse/cre_allies/rqsrc.cre~ ~override/rqsrc.cre~
  WRITE_ASCII 0x280 ~rqsrc~ #32 // Script name aka Death Variable
  WRITE_ASCII 0x2cc ~rqsrc~ #8 // Dialogue file
  SAY BIO ~I am originally from Evereska lets just say I have left after some disagreements with Elders. Now I wish to rebuilt myself here in Amn.~
  SAY NAME1 ~Ilsmavilinn~
  SAY NAME2 ~Ilsmavilinn~

COPY ~golden_horse/cre_allies/rqmin.cre~ ~override/rqmin.cre~
  WRITE_ASCII 0x280 ~rqmin~ #32 // Script name aka Death Variable
  WRITE_ASCII 0x2cc ~rqmin~ #8 // Dialogue file
  SAY BIO ~Elr Navla is traveling invoker, gold bound to fulfill mercenary contract. I am very very confident that you do not need to know more about Elr Navla.~
  SAY NAME1 ~Elr Navla~
  SAY NAME2 ~Elr Navla~

COPY ~golden_horse/cre_allies/rqmtr.cre~ ~override/rqmtr.cre~
  WRITE_ASCII 0x280 ~rqmtr~ #32 // Script name aka Death Variable
  WRITE_ASCII 0x2cc ~rqmtr~ #8 // Dialogue file
  SAY BIO ~Normain Neduzachor is my full name. I was apprentice of Perdan of Waterdeep though that was twenty years ago. Time flies does it not?~
  SAY NAME1 ~Normain~
  SAY NAME2 ~Normain~

COPY ~golden_horse/cre_allies/rqmab.cre~ ~override/rqmab.cre~
  WRITE_ASCII 0x280 ~rqmab~ #32 // Script name aka Death Variable
  WRITE_ASCII 0x2cc ~rqmab~ #8 // Dialogue file
  SAY BIO ~Bekurel is my name and I am very very certain you would you do not want to know anything about my past.~
  SAY NAME1 ~Bekurel~
  SAY NAME2 ~Bekurel~

COPY ~golden_horse/cre_allies/rqmdi.cre~ ~override/rqmdi.cre~
  WRITE_ASCII 0x280 ~rqmdi~ #32 // Script name aka Death Variable
  WRITE_ASCII 0x2cc ~rqmdi~ #8 // Dialogue file
  SAY BIO ~My name is Betheroc. I am a brother of Normain if that is of any interest to you. I was mostly working with him and we did very well for Futher information why don't you ask him I'm not much of a Bard.~
  SAY NAME1 ~Betheroc~
  SAY NAME2 ~Betheroc~

COPY ~golden_horse/cre_allies/rqbsk.cre~ ~override/rqbsk.cre~
  WRITE_ASCII 0x280 ~rqbsk~ #32 // Script name aka Death Variable
  WRITE_ASCII 0x2cc ~rqbsk~ #8 // Dialogue file
  SAY BIO ~I am Afkar. I came faraway land from North to introduce myself I could sing you a song though I am learned enough to know that people of your appearence might not have patience for such things so I would rather not risk it.~
  SAY NAME1 ~Afkar~
  SAY NAME2 ~Afkar~

COPY ~golden_horse/cre_allies/rqmen.cre~ ~override/rqmen.cre~
  WRITE_ASCII 0x280 ~rqmen~ #32 // Script name aka Death Variable
  WRITE_ASCII 0x2cc ~rqmen~ #8 // Dialogue file
  SAY BIO ~I was born in Esmeraltan. I knew not my parents. Life as orphan is hard but Gods gave fortune to compensate my disadvantage, my magic. Learned my specialization from wandering scholar Emre Vilduthviel. I lived in Evereska for a time but found very boorish place. Life is much more interesting when traveling so why not join mercenary company?~
  SAY NAME1 ~Veleten~
  SAY NAME2 ~Veleten~

